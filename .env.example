# === AgriVisionAI Configuration ===

# Groq API (get free key at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Model Configuration
MODEL_PATH=models/best_model.pth
CLASS_NAMES_PATH=models/class_names.json
CONFIDENCE_THRESHOLD=0.60
IMAGE_SIZE=224

# Guardrails
BLUR_THRESHOLD=100.0
MAX_FILE_SIZE_MB=10
MIN_IMAGE_DIMENSION=64

# GPS Farm Region (lat_min, lat_max, lng_min, lng_max)
# Default: Mangalore/Yenepoya region — change to your farm
FARM_LAT_MIN=12.75
FARM_LAT_MAX=13.10
FARM_LNG_MIN=74.75
FARM_LNG_MAX=75.10
FARM_REGION_NAME=Mangalore / Yenepoya Region

# Server
HOST=0.0.0.0
PORT=8000
